<section class="py-16 px-5 sm:px-10 max-w-screen-xl mx-auto vv-fade-up-section">
  <h2 class="font-heading font-semibold text-sm uppercase tracking-widest2 text-vv-black mb-8">
    {{ section.settings.heading }}
  </h2>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
    {%- for block in section.blocks -%}
      {%- assign col = collections[block.settings.collection] -%}
      <div {{ block.shopify_attributes }}>
        <a
          href="{{ block.settings.link_url | default: col.url }}"
          class="group block relative overflow-hidden bg-vv-gray"
          style="aspect-ratio: 4/5;"
        >
          {%- if block.settings.image -%}
            {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', class: 'w-full h-full object-cover group-hover:scale-105 transition-transform duration-700' }}
          {%- elsif col != blank and col.image -%}
            {{ col.image | image_url: width: 800 | image_tag: loading: 'lazy', class: 'w-full h-full object-cover group-hover:scale-105 transition-transform duration-700' }}
          {%- else -%}
            <div class="w-full h-full bg-vv-gray"></div>
          {%- endif -%}
          <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(0,0,0,0.6), transparent 50%);"></div>
          <div class="absolute bottom-0 left-0 right-0 p-5">
            <p class="font-heading font-semibold text-sm uppercase tracking-widest2 text-white">
              {{ block.settings.title | default: col.title }}
            </p>
            <p class="font-body text-xs text-white/70 mt-1">{{ block.settings.description | default: col.description }}</p>
          </div>
        </a>
      </div>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Collections Grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Shop by Collection"
    }
  ],
  "blocks": [
    {
      "type": "collection_tile",
      "name": "Collection Tile",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection (auto-pulls title + image)"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom Image (overrides collection image)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Custom Title (overrides collection title)"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Custom Description"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link URL (overrides collection URL)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collections Grid",
      "blocks": [
        { "type": "collection_tile" },
        { "type": "collection_tile" },
        { "type": "collection_tile" }
      ]
    }
  ],
  "max_blocks": 6
}
{% endschema %}
