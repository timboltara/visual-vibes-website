<section class="bg-white py-20 px-5 sm:px-10 vv-fade-up-section">
  <div class="max-w-screen-xl mx-auto">

    {%- if section.settings.heading != blank -%}
      <div class="text-center mb-12">
        {%- if section.settings.eyebrow != blank -%}
          <p class="font-heading text-vv-orange text-xs uppercase tracking-widest2 mb-3">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        <h2 class="font-heading font-black text-3xl sm:text-4xl uppercase text-vv-black leading-none">{{ section.settings.heading }}</h2>
      </div>
    {%- endif -%}

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {%- for block in section.blocks -%}
        {%- if block.type == 'testimonial' -%}
        <div class="bg-vv-gray p-8" {{ block.shopify_attributes }}>
          {%- comment -%} Stars {%- endcomment -%}
          <div class="flex gap-0.5 mb-5">
            {%- assign star_count = block.settings.rating | default: 5 -%}
            {%- for i in (1..5) -%}
              <span style="color:{%- if i <= star_count -%}#e8622a{%- else -%}#d1d5db{%- endif -%};font-size:16px;">★</span>
            {%- endfor -%}
          </div>
          {%- comment -%} Divider {%- endcomment -%}
          <div class="w-8 h-0.5 bg-vv-orange mb-5"></div>
          {%- comment -%} Quote {%- endcomment -%}
          <p class="font-body text-sm text-vv-black leading-relaxed mb-6">&ldquo;{{ block.settings.quote }}&rdquo;</p>
          {%- comment -%} Attribution {%- endcomment -%}
          <div>
            <p class="font-heading text-xs font-semibold uppercase tracking-widest text-vv-black">{{ block.settings.name }}</p>
            {%- if block.settings.location != blank -%}
              <p class="font-body text-xs text-vv-gray-mid mt-0.5">{{ block.settings.location }}</p>
            {%- endif -%}
          </div>
        </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "What People Are Saying" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Real People. Real Faith." }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        { "type": "range", "id": "rating", "label": "Star Rating", "min": 1, "max": 5, "step": 1, "default": 5 },
        { "type": "textarea", "id": "quote", "label": "Quote" },
        { "type": "text", "id": "name", "label": "Name" },
        { "type": "text", "id": "location", "label": "Location" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "quote": "I wore the Faith Over Fear tee to work and my coworker asked me about it. Led to a 20-minute conversation about Jesus. This brand is literally a ministry.",
            "name": "Marcus T.",
            "location": "Atlanta, GA"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "quote": "The Oversized Grace Sweater is everything. Soft, beautiful, and every time I wear it someone asks where I got it. Love that it opens doors to share my faith.",
            "name": "Destiny R.",
            "location": "Houston, TX"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "quote": "Bought the Vintage Grace Hoodie and it exceeded every expectation. Premium quality, meaningful design. Visual Vibes is the real deal — bold faith, clean drip.",
            "name": "Jordan K.",
            "location": "Chicago, IL"
          }
        }
      ]
    }
  ]
}
{% endschema %}
