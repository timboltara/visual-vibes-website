<div class="max-w-screen-xl mx-auto px-5 sm:px-10 py-10">
  <div class="mb-8">
    <h1 class="font-heading font-black text-3xl uppercase text-vv-black">
      {%- if search.performed -%}
        Search results for &ldquo;{{ search.terms | escape }}&rdquo;
      {%- else -%}
        Search
      {%- endif -%}
    </h1>
    {%- if search.performed -%}
      <p class="font-body text-sm text-vv-gray-mid mt-1">{{ search.results_count }} result{%- if search.results_count != 1 -%}s{%- endif -%}</p>
    {%- endif -%}
  </div>

  <form action="{{ routes.search_url }}" method="get" class="flex gap-3 mb-10 max-w-lg">
    <input type="hidden" name="type" value="product">
    <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="Search products..."
      class="flex-1 border border-gray-300 px-4 py-3 font-body text-sm text-vv-black focus:outline-none focus:border-vv-black transition-colors">
    <button type="submit" class="bg-vv-black text-white font-heading text-xs uppercase tracking-widest px-6 py-3 hover:bg-vv-orange transition-colors">Search</button>
  </form>

  {%- if search.performed -%}
    {%- if search.results_count == 0 -%}
      <p class="font-heading text-sm uppercase tracking-widest text-vv-gray-mid">No results for &ldquo;{{ search.terms | escape }}&rdquo;. Try a different search term.</p>
    {%- else -%}
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3 sm:gap-4">
        {%- for item in search.results -%}
          {%- if item.object_type == 'product' -%}
            {%- render 'product-card', product: item -%}
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  {%- endif -%}
</div>
