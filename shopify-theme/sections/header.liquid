{%- comment -%} Spacer so content doesn't hide under fixed header {%- endcomment -%}
<div id="header-spacer" style="height: {%- if section.settings.show_announcement -%}129px{%- else -%}105px{%- endif -%}"></div>

{%- comment -%} Mobile slide-in drawer {%- endcomment -%}
<div id="mobile-menu-backdrop" class="fixed inset-0 bg-black/50 z-50 md:hidden hidden" aria-hidden="true"></div>

<div
  id="mobile-menu"
  class="fixed top-0 left-0 bottom-0 w-72 bg-white z-50 flex flex-col md:hidden shadow-2xl translate-x-[-100%] transition-transform duration-300"
  aria-label="Mobile navigation"
  role="dialog"
  aria-modal="true"
>
  <div class="flex items-center justify-between px-6 py-5 border-b border-gray-100">
    <a href="{{ routes.root_url }}" id="mobile-menu-logo-link">
      {%- if settings.logo -%}
        {{ settings.logo | image_url: width: 200 | image_tag: style: 'height:36px;width:auto;object-fit:contain;' }}
      {%- else -%}
        <img src="{{ 'visual-vibes-logo-transparent.png' | asset_url }}" alt="{{ shop.name }}" style="height:36px;width:auto;object-fit:contain;">
      {%- endif -%}
    </a>
    <button id="mobile-menu-close" aria-label="Close menu">
      {%- render 'icon-x' -%}
    </button>
  </div>

  <nav class="flex flex-col px-6 py-4 gap-0 flex-1 overflow-y-auto">
    {%- for link in main_menu.links -%}
      {%- liquid
        assign is_him = false
        assign is_her = false
        if link.title contains 'Him' or link.title contains 'him'
          assign is_him = true
        elsif link.title contains 'Her' or link.title contains 'her'
          assign is_her = true
        endif
      -%}
      <div class="border-b border-gray-50">
        <div class="flex items-center justify-between">
          <a href="{{ link.url }}"
             class="block font-heading text-sm uppercase tracking-widest text-vv-black hover:text-vv-orange transition-colors py-3 flex-1">
            {{ link.title }}
          </a>
          {%- if is_him or is_her -%}
            <button class="vv-mobile-expand px-2 py-3 text-vv-gray-mid" aria-expanded="false">
              <span class="vv-mobile-expand-icon block transition-transform duration-200">▾</span>
