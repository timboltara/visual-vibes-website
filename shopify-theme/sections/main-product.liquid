{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign featured_image = current_variant.featured_image | default: product.featured_image
  assign img_filter = 'contrast(1.08) brightness(1.04) saturate(1.2)'
-%}

<div class="pt-0 min-h-screen bg-white">
  <div class="max-w-screen-xl mx-auto px-5 sm:px-10 py-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-14 items-start">

      {%- comment -%} ── Left: Media Gallery ────────────────────────────────────── {%- endcomment -%}
      <div class="lg:sticky lg:top-[145px]">
        {%- comment -%} Main image {%- endcomment -%}
        <div class="relative aspect-square bg-vv-gray overflow-hidden mb-3" id="main-product-image">
          {%- if featured_image -%}
            {{ featured_image | image_url: width: 1200 | image_tag:
              loading: 'eager',
              class: 'w-full h-full object-cover object-top',
              id: 'main-product-img',
              style: 'filter:contrast(1.08) brightness(1.04) saturate(1.2);'
            }}
          {%- else -%}
            <div class="w-full h-full bg-vv-gray flex items-center justify-center">
              <span class="font-heading text-sm uppercase tracking-widest text-vv-gray-mid">No image</span>
            </div>
          {%- endif -%}
        </div>

        {%- comment -%} Thumbnail strip {%- endcomment -%}
        {%- if product.images.size > 1 -%}
          <div class="grid grid-cols-4 gap-2">
            {%- for image in product.images limit: 8 -%}
              <button
                class="vv-thumb aspect-square bg-vv-gray overflow-hidden border-2 {% if forloop.first %}border-vv-black{% else %}border-transparent{% endif %} hover:border-vv-black transition-colors"
                data-image-url="{{ image | image_url: width: 1200 }}"
                data-image-alt="{{ image.alt | escape }}"
              >
                {{ image | image_url: width: 200 | image_tag: loading: 'lazy', class: 'w-full h-full object-cover object-top', style: 'filter:contrast(1.08) brightness(1.04) saturate(1.2);' }}
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} ── Right: Product Info ─────────────────────────────────────── {%- endcomment -%}
      <div>
        {%- comment -%} Tag {%- endcomment -%}
        {%- liquid
          assign tag_label = ''
          assign tag_class = ''
          if product.tags contains 'Best Seller'
            assign tag_label = 'Best Seller'
            assign tag_class = 'bg-vv-orange text-white'
          elsif product.tags contains 'New'
            assign tag_label = 'New'
            assign tag_class = 'bg-vv-black text-white'
          elsif product.tags contains 'Limited'
            assign tag_label = 'Limited'
            assign tag_class = 'bg-vv-black text-white'
          endif
        -%}
        {%- if tag_label != '' -%}
          <span class="inline-block text-[10px] font-heading font-semibold uppercase tracking-widest px-2 py-0.5 mb-3 {{ tag_class }}">
            {{ tag_label }}
          </span>
        {%- endif -%}

        <h1 class="font-heading font-black text-2xl sm:text-3xl uppercase text-vv-black leading-tight mb-2">
          {{ product.title }}
        </h1>

        <div class="flex items-baseline gap-3 mb-4">
          <span class="font-heading text-2xl font-black text-vv-black" id="product-price">
            {{ current_variant.price | money }}
          </span>
          {%- if current_variant.compare_at_price > current_variant.price -%}
            <span class="font-body text-sm text-vv-gray-mid line-through">{{ current_variant.compare_at_price | money }}</span>
          {%- endif -%}
        </div>

        {%- comment -%} Social proof badges (JS randomizes on load) {%- endcomment -%}
        <div class="flex flex-wrap gap-2 mb-5" id="social-proof-badges">
          <span id="viewing-badge" class="font-heading text-[10px] uppercase tracking-widest text-vv-gray-mid border border-gray-200 px-2.5 py-1"></span>
          <span id="low-stock-badge" class="font-heading text-[10px] uppercase tracking-widest text-vv-orange border border-vv-orange px-2.5 py-1 hidden">🔥 Low Stock</span>
          <span id="fan-fav-badge" class="font-heading text-[10px] uppercase tracking-widest text-vv-orange border border-vv-orange px-2.5 py-1 hidden">⭐ Fan Favorite</span>
        </div>

        {%- comment -%} Add to Cart Form {%- endcomment -%}
        {%- form 'product', product, id: 'product-form', data-product-id: product.id -%}
          <input type="hidden" name="id" id="selected-variant-id" value="{{ current_variant.id }}">

          {%- comment -%} Option selectors (Size, Style, etc.) {%- endcomment -%}
          {%- unless product.has_only_default_variant -%}
            {%- for option in product.options_with_values -%}
              <div class="mb-5" data-option-index="{{ forloop.index0 }}">
                <div class="flex items-center justify-between mb-2">
                  <p class="font-heading text-[10px] uppercase tracking-widest text-vv-black font-semibold">
                    {{ option.name }}
                    <span class="text-vv-gray-mid font-normal" id="selected-{{ option.name | handleize }}-label">
                      {%- if option.name == 'Size' -%}— Select a size{%- endif -%}
                    </span>
                  </p>
                  {%- if option.name == 'Size' -%}
                    <button type="button" id="size-guide-btn" class="font-heading text-[10px] uppercase tracking-widest text-vv-gray-mid hover:text-vv-black transition-colors underline">Size Guide</button>
                  {%- endif -%}
                </div>
                <div class="flex flex-wrap gap-2">
                  {%- for value in option.values -%}
                    {%- liquid
                      assign variant_for_value = nil
                      for variant in product.variants
                        if variant.option1 == value or variant.option2 == value or variant.option3 == value
                          assign variant_for_value = variant
                          break
                        endif
                      endfor
                      assign is_available = false
                      if variant_for_value and variant_for_value.available
                        assign is_available = true
                      endif
                    -%}
                    <button
                      type="button"
                      class="vv-option-btn font-heading text-[11px] uppercase tracking-wide px-4 py-2.5 border transition-all {% if is_available %}border-gray-200 text-vv-black hover:border-vv-black{% else %}border-gray-100 text-gray-300 cursor-not-allowed{% endif %}"
                      data-option-name="{{ option.name | escape }}"
                      data-option-value="{{ value | escape }}"
                      data-option-index="{{ forloop.parentloop.index0 }}"
                      {% unless is_available %}disabled{% endunless %}
                    >
                      {{ value }}
                    </button>
                  {%- endfor -%}
                </div>
              </div>
            {%- endfor -%}
          {%- endunless -%}

          {%- comment -%} Validation error {%- endcomment -%}
          <p id="option-error" class="font-heading text-[10px] uppercase tracking-widest text-red-500 mb-3 hidden">
            Please select all options before adding to bag.
          </p>

          {%- comment -%} Add to Cart button {%- endcomment -%}
          <button
            type="submit"
            id="add-to-cart-btn"
            class="w-full bg-vv-black text-white font-heading text-sm font-bold uppercase tracking-widest2 py-4 hover:bg-vv-orange transition-colors duration-200 mt-2"
            {% unless current_variant.available %}disabled{% endunless %}
          >
            {%- if current_variant.available -%}
              <span id="atc-label">Add to Bag</span>
            {%- else -%}
              <span id="atc-label">Sold Out</span>
            {%- endif -%}
          </button>
        {%- endform -%}

        {%- comment -%} Description {%- endcomment -%}
        {%- if product.description != blank -%}
          <div class="mt-6 pt-6 border-t border-gray-100">
            <p class="font-heading text-[10px] uppercase tracking-widest text-vv-black font-semibold mb-3">Details</p>
            <div class="font-body text-sm text-vv-gray-mid leading-relaxed prose">
              {{ product.description }}
            </div>
          </div>
        {%- endif -%}

        {%- comment -%} Trust badges {%- endcomment -%}
        <div class="mt-6 pt-4 border-t border-gray-100 grid grid-cols-2 gap-2">
          {%- for block in section.blocks -%}
            {%- if block.type == 'trust_badge' -%}
              <div class="flex items-center gap-2" {{ block.shopify_attributes }}>
                <span class="text-vv-orange text-xs">✓</span>
                <span class="font-heading text-[10px] uppercase tracking-widest text-vv-gray-mid">{{ block.settings.text }}</span>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </div>
  </div>
</div>

{%- comment -%} Serialize variants for JS {%- endcomment -%}
<script>
  window.vvProduct = {{ product | json }};
  window.vvProductVariants = {{ product.variants | json }};
</script>

{% schema %}
{
  "name": "Product Page",
  "settings": [],
  "blocks": [
    {
      "type": "trust_badge",
      "name": "Trust Badge",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Badge Text",
          "default": "Free shipping on orders $75+"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Page",
      "blocks": [
        { "type": "trust_badge", "settings": { "text": "Free shipping on orders $75+" } },
        { "type": "trust_badge", "settings": { "text": "Easy 30-day returns" } },
        { "type": "trust_badge", "settings": { "text": "Secure checkout" } },
        { "type": "trust_badge", "settings": { "text": "Sizes XS–3XL" } }
      ]
    }
  ]
}
{% endschema %}
