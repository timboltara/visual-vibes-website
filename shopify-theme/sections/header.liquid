{%- liquid
  assign main_menu = linklists[section.settings.main_menu_handle]
-%}

{%- comment -%} Announcement Bar {%- endcomment -%}
{%- if section.settings.show_announcement -%}
<div class="bg-vv-black text-white text-center py-2 px-4">
  <p class="font-heading text-xs tracking-widest2 uppercase">
    Use code
    <span class="text-vv-orange font-semibold">{{ settings.promo_code }}</span>
    — {{ settings.promo_label }}
  </p>
</div>
{%- endif -%}

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 bg-white transition-shadow duration-300"
  style="top: {%- if section.settings.show_announcement -%}0{%- else -%}0{%- endif -%}"
>
  {%- comment -%} Announcement bar spacer handled by JS scroll detection {%- endcomment -%}

  {%- comment -%} Top row: social | logo | icons {%- endcomment -%}
  <div class="border-b border-gray-100 px-5 sm:px-10 h-14 flex items-center justify-between">

    {%- comment -%} Left: social (desktop) {%- endcomment -%}
    <div class="hidden md:flex items-center gap-4">
      {%- if settings.social_instagram != blank -%}
        <a href="{{ settings.social_instagram }}" target="_blank" rel="noopener noreferrer" class="text-vv-black hover:text-vv-orange transition-colors" aria-label="Instagram">
          {%- render 'icon-instagram' -%}
        </a>
      {%- endif -%}
      {%- if settings.social_facebook != blank -%}
        <a href="{{ settings.social_facebook }}" target="_blank" rel="noopener noreferrer" class="text-vv-black hover:text-vv-orange transition-colors" aria-label="Facebook">
          {%- render 'icon-facebook' -%}
        </a>
      {%- endif -%}
    </div>

    {%- comment -%} Mobile hamburger {%- endcomment -%}
    <button
      id="mobile-menu-btn"
      class="md:hidden text-vv-black"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      {%- render 'icon-menu' -%}
    </button>

    {%- comment -%} Center: Logo {%- endcomment -%}
    <a href="{{ routes.root_url }}" class="absolute left-1/2 -translate-x-1/2 flex items-center gap-2.5">
      <div class="w-10 h-10 rounded-full overflow-hidden flex-shrink-0 ring-1 ring-gray-200 bg-vv-black flex items-center justify-center p-0.5">
        {%- if settings.logo -%}
          {{ settings.logo | image_url: width: 80 | image_tag: loading: 'eager', width: 36, height: 36, style: 'width:36px;height:36px;object-fit:contain;' }}
        {%- else -%}
          <img src="{{ 'visual-vibes-logo.png' | asset_url }}" alt="{{ shop.name }}" style="width:36px;height:36px;object-fit:contain;">
        {%- endif -%}
      </div>
      <span class="font-heading font-semibold text-xl sm:text-2xl tracking-widest2 uppercase text-vv-black">
        {{ shop.name }}
      </span>
    </a>

    {%- comment -%} Right: action icons {%- endcomment -%}
    <div class="flex items-center gap-4">
      <button id="search-btn" class="text-vv-black hover:text-vv-orange transition-colors" aria-label="Search">
        {%- render 'icon-search' -%}
      </button>
      {%- if shop.customer_accounts_enabled -%}
        <a href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}"
           class="hidden sm:flex items-center gap-1 text-vv-black hover:text-vv-orange transition-colors relative"
           aria-label="Account">
          {%- render 'icon-user' -%}
          {%- if customer -%}
            <span class="absolute -top-1 -right-1 w-2 h-2 bg-vv-orange rounded-full"></span>
          {%- endif -%}
        </a>
      {%- endif -%}
      <button
        id="cart-drawer-btn"
        class="text-vv-black hover:text-vv-orange transition-colors relative"
        aria-label="Cart"
      >
        {%- render 'icon-bag' -%}
        <span
          id="cart-count-bubble"
          class="absolute -top-1.5 -right-1.5 w-4 h-4 bg-vv-orange rounded-full flex items-center justify-center{%- if cart.item_count == 0 %} hidden{%- endif -%}"
        >
          <span class="font-heading text-white font-bold" style="font-size:9px" id="cart-count-text">{{ cart.item_count }}</span>
        </span>
      </button>
    </div>
  </div>

  {%- comment -%} Bottom row: desktop nav {%- endcomment -%}
  <nav class="hidden md:flex items-center justify-center gap-8 px-10 h-10 border-b border-gray-100" aria-label="Main navigation">
    {%- for link in main_menu.links -%}
      <a
        href="{{ link.url }}"
        class="font-heading text-xs tracking-widest uppercase transition-colors duration-200 {% if link.active %}text-vv-orange border-b border-vv-orange pb-px{% else %}text-vv-black hover:text-vv-orange{% endif %}"
      >
        {{ link.title }}
      </a>
    {%- endfor -%}
  </nav>
</header>

{%- comment -%} Spacer so content doesn't hide under fixed header {%- endcomment -%}
<div id="header-spacer" style="height: {%- if section.settings.show_announcement -%}129px{%- else -%}105px{%- endif -%}"></div>

{%- comment -%} Mobile slide-in drawer {%- endcomment -%}
<div id="mobile-menu-backdrop" class="fixed inset-0 bg-black/50 z-50 md:hidden hidden" aria-hidden="true"></div>

<div
  id="mobile-menu"
  class="fixed top-0 left-0 bottom-0 w-72 bg-white z-50 flex flex-col md:hidden shadow-2xl translate-x-[-100%] transition-transform duration-300"
  aria-label="Mobile navigation"
  role="dialog"
  aria-modal="true"
>
  <div class="flex items-center justify-between px-6 py-5 border-b border-gray-100">
    <a href="{{ routes.root_url }}" class="flex items-center gap-2" id="mobile-menu-logo-link">
      <div class="w-9 h-9 rounded-full overflow-hidden flex-shrink-0 ring-1 ring-gray-200 bg-vv-black flex items-center justify-center p-0.5">
        {%- if settings.logo -%}
          {{ settings.logo | image_url: width: 64 | image_tag: width: 32, height: 32, style: 'width:32px;height:32px;object-fit:contain;' }}
        {%- else -%}
          <img src="{{ 'visual-vibes-logo.png' | asset_url }}" alt="{{ shop.name }}" style="width:32px;height:32px;object-fit:contain;">
        {%- endif -%}
      </div>
      <span class="font-heading font-semibold text-lg uppercase tracking-widest2 text-vv-black">{{ shop.name }}</span>
    </a>
    <button id="mobile-menu-close" aria-label="Close menu">
      {%- render 'icon-x' -%}
    </button>
  </div>

  <nav class="flex flex-col px-6 py-6 gap-1 flex-1">
    {%- for link in main_menu.links -%}
      <a href="{{ link.url }}"
         class="block font-heading text-sm uppercase tracking-widest text-vv-black hover:text-vv-orange transition-colors py-3 border-b border-gray-50">
        {{ link.title }}
      </a>
    {%- endfor -%}
    {%- if shop.customer_accounts_enabled -%}
      <a href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}"
         class="flex items-center gap-2 font-heading text-sm uppercase tracking-widest text-vv-black hover:text-vv-orange transition-colors py-3 border-b border-gray-50">
        {%- render 'icon-user' -%}
        {%- if customer -%}Hi, {{ customer.first_name }}{%- else -%}Account{%- endif -%}
      </a>
    {%- endif -%}
    <button id="mobile-search-btn"
      class="flex items-center gap-2 font-heading text-sm uppercase tracking-widest text-vv-black hover:text-vv-orange transition-colors py-3 border-b border-gray-50 w-full text-left">
      {%- render 'icon-search' -%} Search
    </button>
  </nav>

  <div class="px-6 py-6 border-t border-gray-100">
    <p class="font-heading text-xs uppercase tracking-widest text-vv-gray-mid mb-1">First order discount</p>
    <p class="font-heading font-semibold text-vv-orange text-base tracking-widest">{{ settings.promo_code }}</p>
    <div class="flex gap-4 mt-4">
      {%- if settings.social_instagram != blank -%}
        <a href="{{ settings.social_instagram }}" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
          {%- render 'icon-instagram', size: 20 -%}
        </a>
      {%- endif -%}
      {%- if settings.social_facebook != blank -%}
        <a href="{{ settings.social_facebook }}" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
          {%- render 'icon-facebook', size: 20 -%}
        </a>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Show announcement bar",
      "default": true
    },
    {
      "type": "link_list",
      "id": "main_menu_handle",
      "label": "Main Menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
