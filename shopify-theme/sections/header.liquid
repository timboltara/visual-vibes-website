{%- liquid
  assign main_menu = linklists[section.settings.main_menu_handle]
-%}

{%- comment -%} Announcement Bar {%- endcomment -%}
{%- if section.settings.show_announcement -%}
<div class="bg-vv-black text-white text-center py-2 px-4">
  <p class="font-heading text-xs tracking-widest2 uppercase">
    Use code
    <span class="text-vv-orange font-semibold">{{ settings.promo_code }}</span>
    — {{ settings.promo_label }}
  </p>
</div>
{%- endif -%}

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 bg-white transition-shadow duration-300">

  {%- comment -%} Top row: social | logo | icons {%- endcomment -%}
  <div class="border-b border-gray-100 px-5 sm:px-10 h-14 flex items-center justify-between">

    {%- comment -%} Left: social (desktop) {%- endcomment -%}
    <div class="hidden md:flex items-center gap-4">
      {%- if settings.social_instagram != blank -%}
        <a href="{{ settings.social_instagram }}" target="_blank" rel="noopener noreferrer" class="text-vv-black hover:text-vv-orange transition-colors" aria-label="Instagram">
          {%- render 'icon-instagram' -%}
        </a>
      {%- endif -%}
      {%- if settings.social_facebook != blank -%}
        <a href="{{ settings.social_facebook }}" target="_blank" rel="noopener noreferrer" class="text-vv-black hover:text-vv-orange transition-colors" aria-label="Facebook">
          {%- render 'icon-facebook' -%}
        </a>
      {%- endif -%}
    </div>

    {%- comment -%} Mobile hamburger {%- endcomment -%}
    <button id="mobile-menu-btn" class="md:hidden text-vv-black" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
      {%- render 'icon-menu' -%}
    </button>

    {%- comment -%} Center: Logo {%- endcomment -%}
    <a href="{{ routes.root_url }}" class="absolute left-1/2 -translate-x-1/2">
      {%- if settings.logo -%}
        {%- assign logo_style = 'height:44px;width:auto;max-width:' | append: settings.logo_width | append: 'px;object-fit:contain;' -%}
        {{ settings.logo | image_url: width: 400 | image_tag: loading: 'eager', style: logo_style }}
      {%- else -%}
        <img src="{{ 'visual-vibes-logo-transparent.png' | asset_url }}" alt="{{ shop.name }}" style="height:44px;width:auto;object-fit:contain;">
      {%- endif -%}
    </a>

    {%- comment -%} Right: action icons {%- endcomment -%}
    <div class="flex items-center gap-4">
      <button id="search-btn" class="text-vv-black hover:text-vv-orange transition-colors" aria-label="Search">
        {%- render 'icon-search' -%}
      </button>
      {%- if shop.customer_accounts_enabled -%}
        <a href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}"
           class="hidden sm:flex items-center gap-1 text-vv-black hover:text-vv-orange transition-colors relative" aria-label="Account">
          {%- render 'icon-user' -%}
          {%- if customer -%}
            <span class="absolute -top-1 -right-1 w-2 h-2 bg-vv-orange rounded-full"></span>
          {%- endif -%}
        </a>
      {%- endif -%}
      <button id="cart-drawer-btn" class="text-vv-black hover:text-vv-orange transition-colors relative" aria-label="Cart">
        {%- render 'icon-bag' -%}
        <span id="cart-count-bubble" class="absolute -top-1.5 -right-1.5 w-4 h-4 bg-vv-orange rounded-full flex items-center justify-center{%- if cart.item_count == 0 %} hidden{%- endif -%}">
          <span class="font-heading text-white font-bold" style="font-size:9px" id="cart-count-text">{{ cart.item_count }}</span>
        </span>
      </button>
    </div>
  </div>

  {%- comment -%} ── Desktop Nav + Mega Menu Container ──────────────── {%- endcomment -%}
  <div class="hidden md:block relative" id="nav-with-mega">

    {%- comment -%} Nav bar {%- endcomment -%}
    <nav class="flex items-center justify-center gap-8 px-10 h-10 border-b border-gray-100" aria-label="Main navigation">
      {%- assign nav_links = main_menu.links -%}
      {%- if nav_links.size == 0 -%}
        {%- assign use_fallback_nav = true -%}
      {%- endif -%}
      {%- if use_fallback_nav -%}
        <a href="/collections/all" class="vv-nav-link font-heading text-xs tracking-widest uppercase transition-colors duration-200 text-vv-black hover:text-vv-orange" data-mega="shop-all">Shop All <span class="text-[8px] opacity-40 translate-y-px">▾</span></a>
        <a href="/collections/for-him" class="vv-nav-link font-heading text-xs tracking-widest uppercase transition-colors duration-200 text-vv-black hover:text-vv-orange" data-mega="for-him">For Him <span class="text-[8px] opacity-40 translate-y-px">▾</span></a>
        <a href="/collections/for-her" class="vv-nav-link font-heading text-xs tracking-widest uppercase transition-colors duration-200 text-vv-black hover:text-vv-orange" data-mega="for-her">For Her <span class="text-[8px] opacity-40 translate-y-px">▾</span></a>
        <a href="/collections" class="vv-nav-link font-heading text-xs tracking-widest uppercase transition-colors duration-200 text-vv-black hover:text-vv-orange" data-mega="collections">Collections <span class="text-[8px] opacity-40 translate-y-px">▾</span></a>
        <a href="/pages/about" class="vv-nav-link font-heading text-xs tracking-widest uppercase transition-colors duration-200 text-vv-black hover:text-vv-orange">Our Story</a>
      {%- else -%}
      {%- for link in main_menu.links -%}
        {%- liquid
          assign link_slug = link.title | downcase | replace: ' ', '-'
          assign has_mega = false
          if link.title contains 'Him' or link.title contains 'him'
            assign has_mega = true
            assign mega_panel = 'for-him'
          elsif link.title contains 'Her' or link.title contains 'her'
            assign has_mega = true
            assign mega_panel = 'for-her'
          elsif link.title contains 'Collection' or link.title contains 'collection'
            assign has_mega = true
            assign mega_panel = 'collections'
          elsif link.title contains 'Shop' or link.title contains 'shop'
            assign has_mega = true
            assign mega_panel = 'shop-all'
          endif
        -%}
        <a
          href="{{ link.url }}"
          class="vv-nav-link font-heading text-xs tracking-widest uppercase transition-colors duration-200 flex items-center gap-1 {% if link.active %}text-vv-orange border-b border-vv-orange pb-px{% else %}text-vv-black hover:text-vv-orange{% endif %}"
          {%- if has_mega -%} data-mega="{{ mega_panel }}"{%- endif -%}
        >
          {{ link.title }}
          {%- if has_mega -%}<span class="text-[8px] opacity-40 translate-y-px">▾</span>{%- endif -%}
        </a>
      {%- endfor -%}
      {%- endif -%}
    </nav>

    {%- comment -%} ── Mega Menu Panels ────────────────────────────────── {%- endcomment -%}
