{%- comment -%}
  Usage: {% render 'product-card', product: product %}
{%- endcomment -%}

{%- liquid
  assign img_filter = 'contrast(1.08) brightness(1.04) saturate(1.2)'
  assign hover_img = product.images[1]
  assign tag_label = ''
  assign tag_class = ''
  if product.tags contains 'Best Seller'
    assign tag_label = 'Best Seller'
    assign tag_class = 'bg-vv-orange text-white'
  elsif product.tags contains 'New'
    assign tag_label = 'New'
    assign tag_class = 'bg-vv-black text-white'
  elsif product.tags contains 'Limited'
    assign tag_label = 'Limited'
    assign tag_class = 'bg-vv-black text-white'
  endif
-%}

<div class="group vv-fade-up">
  <a href="{{ product.url }}" class="block relative bg-vv-gray overflow-hidden mb-3" style="aspect-ratio: 1/1;">

    {%- comment -%} Primary image {%- endcomment -%}
    {%- if product.featured_image -%}
      {{ product.featured_image | image_url: width: 600 | image_tag:
        loading: 'lazy',
        class: 'w-full h-full object-cover object-top transition-opacity duration-400',
        style: 'filter:contrast(1.08) brightness(1.04) saturate(1.2);'
      }}
    {%- else -%}
      <div class="w-full h-full bg-vv-gray flex items-center justify-center">
        <span class="font-heading text-xs uppercase tracking-widest text-vv-gray-mid">No image</span>
      </div>
    {%- endif -%}

    {%- comment -%} Hover / back-of-product image {%- endcomment -%}
    {%- if hover_img -%}
      <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-400">
        {{ hover_img | image_url: width: 600 | image_tag:
          loading: 'lazy',
          class: 'w-full h-full object-cover object-top',
          style: 'filter:contrast(1.08) brightness(1.04) saturate(1.2);'
        }}
      </div>
    {%- else -%}
      {%- comment -%} No second image — scale effect instead {%- endcomment -%}
      <div class="absolute inset-0 transition-transform duration-500 group-hover:scale-105 pointer-events-none"></div>
    {%- endif -%}

    {%- comment -%} Badge label {%- endcomment -%}
    {%- if tag_label != '' -%}
      <span class="absolute top-2 left-2 text-[10px] font-heading font-semibold uppercase tracking-widest px-2 py-0.5 z-10 {{ tag_class }}">
        {{ tag_label }}
      </span>
    {%- endif -%}

    {%- comment -%} Quick Add on hover {%- endcomment -%}
    <div class="absolute bottom-0 left-0 right-0 translate-y-full group-hover:translate-y-0 transition-transform duration-300 bg-white/95 backdrop-blur-sm p-2 z-10">
      <p class="font-heading text-[9px] uppercase tracking-widest text-vv-gray-mid mb-1.5 text-center">Quick Add</p>
      <div class="flex gap-1 justify-center flex-wrap">
        {%- assign shown_sizes = '' -%}
        {%- for variant in product.variants -%}
          {%- if variant.available -%}
            {%- assign size_label = variant.title | split: ' / ' | first -%}
            {%- unless shown_sizes contains size_label -%}
              <button
                class="vv-quick-add-btn font-heading text-[10px] uppercase tracking-wide px-2 py-1 border border-gray-300 text-vv-black hover:border-vv-black hover:bg-vv-black hover:text-white transition-all duration-100"
                data-variant-id="{{ variant.id }}"
                data-product-title="{{ product.title | escape }}"
              >
                {{ size_label }}
              </button>
              {%- assign shown_sizes = shown_sizes | append: size_label | append: '|' -%}
            {%- endunless -%}
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </a>

  <a href="{{ product.url }}" class="block">
    <p class="font-heading text-[11px] uppercase tracking-widest text-vv-black font-medium leading-snug line-clamp-2">
      {{ product.title }}
    </p>
    {%- comment -%} Star rating preview (Product Reviews app metafields) {%- endcomment -%}
    {%- if product.metafields.reviews.rating.value != blank -%}
      <div class="flex items-center gap-1 mt-0.5">
        {%- assign rating_val = product.metafields.reviews.rating.value | times: 1 -%}
        {%- for i in (1..5) -%}
          <span style="font-size:11px; color: {%- if i <= rating_val -%}#e8622a{%- else -%}#d1d5db{%- endif -%};">★</span>
        {%- endfor -%}
        {%- if product.metafields.reviews.rating_count.value != blank -%}
          <span class="font-body text-[10px] text-vv-gray-mid">({{ product.metafields.reviews.rating_count.value }})</span>
        {%- endif -%}
      </div>
    {%- endif -%}
    <p class="font-body text-sm text-vv-black font-semibold mt-0.5">
      {{ product.price | money }}
    </p>
  </a>
</div>
