<div class="min-h-screen bg-white">

  {%- comment -%} Page header {%- endcomment -%}
  <div class="px-5 sm:px-10 pt-10 pb-6 max-w-screen-xl mx-auto">
    <h1 class="font-heading font-black text-4xl sm:text-5xl uppercase text-vv-black leading-none">
      {{ section.settings.heading }}
    </h1>
    {%- if section.settings.subheading != blank -%}
      <p class="font-heading text-[10px] uppercase tracking-widest text-vv-orange mt-2">{{ section.settings.subheading }}</p>
    {%- endif -%}
  </div>

  {%- comment -%} Trust bar {%- endcomment -%}
  <div class="bg-vv-gray border-y border-gray-200 mb-10">
    <div class="max-w-screen-xl mx-auto px-5 sm:px-10 py-2.5 flex flex-wrap gap-x-8 gap-y-1 justify-center sm:justify-start">
      <span class="font-heading text-[10px] uppercase tracking-widest text-vv-gray-mid flex items-center gap-1.5"><span class="text-vv-orange">✓</span>Free shipping on orders $75+</span>
      <span class="font-heading text-[10px] uppercase tracking-widest text-vv-gray-mid flex items-center gap-1.5"><span class="text-vv-orange">✓</span>Easy returns</span>
      <span class="font-heading text-[10px] uppercase tracking-widest text-vv-gray-mid flex items-center gap-1.5"><span class="text-vv-orange">✓</span>Secure checkout</span>
      <span class="font-heading text-[10px] uppercase tracking-widest text-vv-gray-mid flex items-center gap-1.5"><span class="text-vv-orange">✓</span>Sizes XS–3XL</span>
    </div>
  </div>

  {%- comment -%} Collections grid {%- endcomment -%}
  <div class="max-w-screen-xl mx-auto px-5 sm:px-10 pb-16">
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4 sm:gap-6">
      {%- for collection in collections -%}
        {%- unless collection.handle == 'frontpage' or collection.handle == 'featured' -%}
        <a href="{{ collection.url }}" class="group block vv-fade-up">
          <div class="relative bg-vv-gray overflow-hidden mb-3" style="aspect-ratio: 1/1;">
            {%- if collection.image -%}
              {{ collection.image | image_url: width: 600 | image_tag:
                loading: 'lazy',
                class: 'w-full h-full object-cover object-center transition-transform duration-500 group-hover:scale-105',
                style: 'filter:contrast(1.05) brightness(1.02) saturate(1.1);'
              }}
            {%- elsif collection.products.first and collection.products.first.featured_image -%}
              {{ collection.products.first.featured_image | image_url: width: 600 | image_tag:
                loading: 'lazy',
                class: 'w-full h-full object-cover object-top transition-transform duration-500 group-hover:scale-105',
                style: 'filter:contrast(1.05) brightness(1.02) saturate(1.1);'
              }}
            {%- else -%}
              <div class="w-full h-full bg-vv-gray flex items-center justify-center">
                <span class="font-heading text-xs uppercase tracking-widest text-vv-gray-mid">{{ collection.title | truncate: 12 }}</span>
              </div>
            {%- endif -%}
            <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-colors duration-300"></div>
            <div class="absolute bottom-0 left-0 right-0 p-3 translate-y-full group-hover:translate-y-0 transition-transform duration-300 bg-vv-orange">
              <p class="font-heading text-[10px] uppercase tracking-widest text-white text-center">Shop Now</p>
            </div>
          </div>
          <p class="font-heading text-[11px] uppercase tracking-widest text-vv-black font-semibold leading-snug">{{ collection.title }}</p>
          <p class="font-body text-xs text-vv-gray-mid mt-0.5">{{ collection.products_count }} products</p>
        </a>
        {%- endunless -%}
      {%- endfor -%}
    </div>
  </div>

</div>

{% schema %}
{
  "name": "Collections List",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "All Collections"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Faith You Can Wear"
    }
  ],
  "presets": [
    {
      "name": "Collections List",
      "settings": {
        "heading": "All Collections",
        "subheading": "Faith You Can Wear"
      }
    }
  ]
}
{% endschema %}
