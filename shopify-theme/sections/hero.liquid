<section id="vv-hero" class="relative w-full overflow-hidden flex flex-col" style="height: calc(100vh - 88px); min-height: 520px;">

  {%- comment -%} ── Video Background (future-ready) ─────────────────── {%- endcomment -%}
  {%- if section.settings.video_url != blank -%}
    <video
      class="absolute inset-0 w-full h-full object-cover"
      autoplay muted loop playsinline
      poster="{%- if section.settings.bg_image -%}{{ section.settings.bg_image | image_url: width: 2000 }}{%- endif -%}"
    >
      <source src="{{ section.settings.video_url }}" type="video/mp4">
    </video>
    <div class="absolute inset-0" style="background: rgba(0,0,0,{{ section.settings.video_overlay | divided_by: 100.0 }});"></div>

  {%- elsif section.settings.bg_image -%}
    {%- comment -%} ── Static Background Image ───────────────────────── {%- endcomment -%}
    <div class="absolute inset-0">
      {{ section.settings.bg_image | image_url: width: 2000 | image_tag:
        loading: 'eager',
        class: 'w-full h-full object-cover object-center'
      }}
      <div class="absolute inset-0" style="background: rgba(0,0,0,{{ section.settings.overlay_opacity | divided_by: 100.0 }});"></div>
    </div>

  {%- else -%}
    {%- comment -%} ── Gradient Fallback ─────────────────────────────── {%- endcomment -%}
    <div class="absolute inset-0" style="background: linear-gradient(135deg, {{ section.settings.bg_color }} 0%, #1a1a1a 50%, #262626 100%);"></div>
    <div class="absolute inset-0" style="opacity:0.25; background-image: radial-gradient(ellipse at 25% 65%, {{ settings.color_accent }} 0%, transparent 50%), radial-gradient(ellipse at 78% 20%, #bf4f1e 0%, transparent 45%);"></div>
  {%- endif -%}

  {%- comment -%} ── Content — spread top/center/bottom ────────────────── {%- endcomment -%}
  <div class="relative z-10 flex flex-col items-center justify-between h-full px-6 py-8 text-center vv-fade-up">

    {%- comment -%} Top: eyebrow label {%- endcomment -%}
    {%- if section.settings.eyebrow != blank -%}
      <p class="font-heading text-vv-orange text-xs tracking-widest3 uppercase">{{ section.settings.eyebrow }}</p>
    {%- else -%}
      <span></span>
    {%- endif -%}

    {%- comment -%} Center: heading + subheading {%- endcomment -%}
    <div class="flex flex-col items-center gap-4">
      <div
        class="font-heading font-black uppercase leading-tight text-center"
        style="font-size: clamp(2.8rem, 8vw, 7.5rem); letter-spacing: -0.01em;"
        role="heading" aria-level="1"
      >
        {%- comment -%} Line 1 — solid white {%- endcomment -%}
        <span class="block text-white">{{ section.settings.heading_line1 }}</span>

        {%- comment -%}
          Line 2 — SVG outlined text.
          fill="none" means letter interiors are fully transparent.
          No overlapping strokes inside A / E / W counters.
        {%- endcomment -%}
        <span class="sr-only">{{ section.settings.heading_line2 }}</span>
        <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg"
          style="display:block;width:100%;height:1em;overflow:visible;margin-top:0.05em;">
          <text x="50%" y="0.82em" text-anchor="middle"
            fill="none" stroke="white" stroke-width="2"
            style="font-family:Montserrat,sans-serif;font-weight:900;font-size:1em;letter-spacing:-0.01em;text-transform:uppercase;">
            {{ section.settings.heading_line2 }}
          </text>
        </svg>
      </div>

      {%- if section.settings.subheading != blank -%}
        <p class="font-body text-white/60 text-sm max-w-sm">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    {%- comment -%} Bottom: CTAs {%- endcomment -%}
    <div class="flex gap-3 flex-wrap justify-center">
      {%- if section.settings.btn1_label != blank -%}
        <a
          href="{{ section.settings.btn1_url }}"
          class="inline-block bg-vv-orange text-white font-heading text-xs font-semibold uppercase tracking-widest2 px-10 py-4 hover:bg-white hover:text-vv-black transition-colors duration-300"
        >
          {{ section.settings.btn1_label }}
        </a>
      {%- endif -%}
      {%- if section.settings.btn2_label != blank -%}
        <a
          href="{{ section.settings.btn2_url }}"
          class="inline-block border border-white/40 text-white font-heading text-xs font-semibold uppercase tracking-widest2 px-10 py-4 hover:bg-white hover:text-vv-black transition-colors duration-300"
        >
          {{ section.settings.btn2_label }}
        </a>
      {%- endif -%}
    </div>
  </div>

  {%- comment -%} Bottom fade {%- endcomment -%}
  <div class="absolute bottom-0 left-0 right-0 h-32" style="background: linear-gradient(to top, rgba(0,0,0,0.4), transparent);"></div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color (used when no image/video)",
      "default": "#1c1c1c"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image (overrides color)"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Image Overlay Darkness (%)",
      "min": 0,
      "max": 90,
      "step": 5,
      "default": 50
    },
    {
      "type": "header",
      "content": "Video Background (overrides image)"
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "Video URL (.mp4)",
      "info": "Upload your video to Shopify Files or use a CDN URL. Leave blank to use image/color background."
    },
    {
      "type": "range",
      "id": "video_overlay",
      "label": "Video Overlay Darkness (%)",
      "min": 0,
      "max": 80,
      "step": 5,
      "default": 40
    },
    {
      "type": "header",
      "content": "Text Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "ON FIRE FOR JESUS"
    },
    {
      "type": "text",
      "id": "heading_line1",
      "label": "Heading Line 1 (solid white)",
      "default": "Faith You"
    },
    {
      "type": "text",
      "id": "heading_line2",
      "label": "Heading Line 2 (outlined)",
      "default": "Can Wear"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Bold Christian apparel that helps people live on fire for God."
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "text",
      "id": "btn1_label",
      "label": "Button 1 Label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "btn1_url",
      "label": "Button 1 URL"
    },
    {
      "type": "text",
      "id": "btn2_label",
      "label": "Button 2 Label",
      "default": "Our Story"
    },
    {
      "type": "url",
      "id": "btn2_url",
      "label": "Button 2 URL"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner",
      "settings": {
        "eyebrow": "ON FIRE FOR JESUS",
        "heading_line1": "Faith You",
        "heading_line2": "Can Wear",
        "subheading": "Bold Christian apparel that helps people live on fire for God.",
        "btn1_label": "Shop Now",
        "btn2_label": "Our Story"
      }
    }
  ]
}
{% endschema %}
