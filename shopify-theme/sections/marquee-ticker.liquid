<div class="bg-vv-black py-3 overflow-hidden border-y border-white/5">
  <div class="marquee-track" style="animation: marquee {{ section.settings.speed }}s linear infinite; width: max-content; display: flex;">
    {%- assign items = section.blocks -%}
    {%- comment -%} Triple the items so the loop is seamless {%- endcomment -%}
    {%- for pass in (1..3) -%}
      {%- for block in section.blocks -%}
        <span class="flex items-center gap-0" {{ block.shopify_attributes }}>
          <span class="font-heading text-xs uppercase tracking-widest2 text-white whitespace-nowrap px-6">
            {{ block.settings.text }}
          </span>
          <span class="text-vv-orange text-xs">✦</span>
        </span>
      {%- endfor -%}
    {%- endfor -%}
  </div>
</div>

<style>
  @keyframes marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-33.333%); }
  }
  .marquee-track:hover { animation-play-state: paused; }
</style>

{% schema %}
{
  "name": "Marquee Ticker",
  "settings": [
    {
      "type": "range",
      "id": "speed",
      "label": "Scroll Speed (seconds)",
      "min": 10,
      "max": 60,
      "step": 2,
      "default": 26,
      "info": "Lower = faster"
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Ticker Item",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Faith You Can Wear"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Marquee Ticker",
      "blocks": [
        { "type": "item", "settings": { "text": "Faith You Can Wear" } },
        { "type": "item", "settings": { "text": "On Fire For Jesus" } },
        { "type": "item", "settings": { "text": "Bold Faith" } },
        { "type": "item", "settings": { "text": "Building Disciples Through Design" } },
        { "type": "item", "settings": { "text": "Romans 1:16" } },
        { "type": "item", "settings": { "text": "Faith is Not Passive" } },
        { "type": "item", "settings": { "text": "New Drop" } },
        { "type": "item", "settings": { "text": "Use Code BLESSED26" } }
      ]
    }
  ]
}
{% endschema %}
