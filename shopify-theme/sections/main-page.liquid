<div class="min-h-screen bg-white">
  <div class="max-w-3xl mx-auto px-5 sm:px-10 py-16">
    {%- if section.settings.show_title -%}
      <h1 class="font-heading font-black text-3xl sm:text-4xl uppercase text-vv-black leading-tight mb-10">
        {{ page.title }}
      </h1>
    {%- endif -%}
    {%- if page.content != blank -%}
      <div class="font-body text-base text-vv-black leading-relaxed prose max-w-none">
        {{ page.content }}
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Page",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_title",
      "label": "Show Page Title",
      "default": true
    }
  ],
  "presets": [
    { "name": "Page" }
  ]
}
{% endschema %}
