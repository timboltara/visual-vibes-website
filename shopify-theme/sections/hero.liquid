<section class="relative w-full overflow-hidden" style="height: calc(100vh - 88px);">
  {%- comment -%} Background gradient {%- endcomment -%}
  <div class="absolute inset-0" style="background: linear-gradient(135deg, {{ section.settings.bg_color }} 0%, #1a1a1a 50%, #262626 100%);"></div>

  {%- comment -%} Color overlay {%- endcomment -%}
  <div
    class="absolute inset-0"
    style="opacity: 0.25; background-image: radial-gradient(ellipse at 25% 65%, {{ settings.color_accent }} 0%, transparent 50%), radial-gradient(ellipse at 78% 20%, #bf4f1e 0%, transparent 45%);"
  ></div>

  {%- comment -%} Background image (optional) {%- endcomment -%}
  {%- if section.settings.bg_image -%}
    <div class="absolute inset-0">
      {{ section.settings.bg_image | image_url: width: 2000 | image_tag: loading: 'eager', class: 'w-full h-full object-cover object-center' }}
      <div class="absolute inset-0" style="background: rgba(0,0,0,{{ section.settings.overlay_opacity | divided_by: 100.0 }});"></div>
    </div>
  {%- endif -%}

  {%- comment -%} Content {%- endcomment -%}
  <div class="absolute bottom-16 left-0 right-0 flex flex-col items-center gap-6 px-6 text-center vv-fade-up">
    {%- if section.settings.eyebrow != blank -%}
      <p class="font-heading text-vv-orange text-xs tracking-widest3 uppercase">{{ section.settings.eyebrow }}</p>
    {%- endif -%}

    <h1
      class="font-heading font-black text-white uppercase leading-none"
      style="font-size: clamp(3.5rem, 10vw, 9rem); letter-spacing: -0.01em;"
    >
      {{ section.settings.heading_line1 }}
      <br>
      <span style="-webkit-text-stroke: 2px white; color: transparent;">
        {{ section.settings.heading_line2 }}
      </span>
    </h1>

    {%- if section.settings.subheading != blank -%}
      <p class="font-body text-white/60 text-sm max-w-sm">{{ section.settings.subheading }}</p>
    {%- endif -%}

    <div class="flex gap-3 flex-wrap justify-center">
      {%- if section.settings.btn1_label != blank -%}
        <a
          href="{{ section.settings.btn1_url }}"
          class="inline-block bg-vv-orange text-white font-heading text-xs font-semibold uppercase tracking-widest2 px-10 py-4 hover:bg-white hover:text-vv-black transition-colors duration-300"
        >
          {{ section.settings.btn1_label }}
        </a>
      {%- endif -%}
      {%- if section.settings.btn2_label != blank -%}
        <a
          href="{{ section.settings.btn2_url }}"
          class="inline-block border border-white/40 text-white font-heading text-xs font-semibold uppercase tracking-widest2 px-10 py-4 hover:bg-white hover:text-vv-black transition-colors duration-300"
        >
          {{ section.settings.btn2_label }}
        </a>
      {%- endif -%}
    </div>
  </div>

  {%- comment -%} Bottom fade {%- endcomment -%}
  <div class="absolute bottom-0 left-0 right-0 h-32" style="background: linear-gradient(to top, rgba(0,0,0,0.4), transparent);"></div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#1c1c1c"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image (optional — overrides color)"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Image Overlay Darkness (%)",
      "min": 0,
      "max": 90,
      "step": 5,
      "default": 50
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "ON FIRE FOR JESUS"
    },
    {
      "type": "text",
      "id": "heading_line1",
      "label": "Heading Line 1",
      "default": "Faith You"
    },
    {
      "type": "text",
      "id": "heading_line2",
      "label": "Heading Line 2 (outlined)",
      "default": "Can Wear"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Bold Christian apparel that helps people live on fire for God."
    },
    {
      "type": "text",
      "id": "btn1_label",
      "label": "Button 1 Label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "btn1_url",
      "label": "Button 1 URL"
    },
    {
      "type": "text",
      "id": "btn2_label",
      "label": "Button 2 Label",
      "default": "Our Story"
    },
    {
      "type": "url",
      "id": "btn2_url",
      "label": "Button 2 URL"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner",
      "settings": {
        "eyebrow": "ON FIRE FOR JESUS",
        "heading_line1": "Faith You",
        "heading_line2": "Can Wear",
        "subheading": "Bold Christian apparel that helps people live on fire for God.",
        "btn1_label": "Shop Now",
        "btn2_label": "Our Story"
      }
    }
  ]
}
{% endschema %}
